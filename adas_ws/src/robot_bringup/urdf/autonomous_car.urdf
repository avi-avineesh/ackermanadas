<?xml version="1.0" encoding="utf-8"?>
<!-- Autonomous Car URDF — Modified from SolidWorks export
     Changes from original:
     1. Mesh paths updated to package://robot_bringup/meshes/
     2. Front knuckle joints changed from continuous → revolute with ±0.6 rad limits
     3. Front wheel joints have near-zero friction (free-spinning, no motor)
     4. Gazebo Harmonic plugins added for Ackermann steering + sensors
     FIX v2: All 4 wheel axes aligned to "0 0 1" (no more reverse spin)
     FIX v3: All 4 wheel COLLISIONS changed from mesh → cylinder (smooth rolling)
             right_front VISUAL restored to mesh (was accidentally cylinder)
-->
<robot name="autonomous_car">

  <!-- ============================================================== -->
  <!--  BASE LINK (chassis + motors + rack + servo — all fixed parts) -->
  <!-- ============================================================== -->
  <link name="base_link">
    <inertial>
      <origin xyz="-0.000231100476171808 6.21990214888513E-09 -0.0148754815796431" rpy="0 0 0"/>
      <mass value="0.723731533085621"/>
      <inertia ixx="0.00273550214547189" ixy="-4.84629719487281E-10" ixz="0.00048548168745002"
               iyy="0.00771136853796671" iyz="1.27964592506478E-10"  izz="0.0102201832153108"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_bringup/meshes/base_link.STL"/>
      </geometry>
      <material name="chassis_grey">
        <color rgba="0.792 0.820 0.933 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_bringup/meshes/base_link.STL"/>
      </geometry>
    </collision>
  </link>

  <!-- ============================================================== -->
  <!--  LEFT REAR WHEEL (powered — continuous joint)                  -->
  <!-- ============================================================== -->
  <link name="left_rear">
    <inertial>
      <origin xyz="3.10904498124209E-06 5.37279659429402E-06 -0.0120230697296975" rpy="0 0 0"/>
      <mass value="0.126363111272001"/>
      <inertia ixx="7.94253978332532E-05" ixy="1.60497325337193E-09" ixz="2.88800419661742E-09"
               iyy="7.94272648265278E-05" iyz="5.03999377505508E-09"  izz="0.00013565032153422"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_bringup/meshes/left_rear.STL"/>
      </geometry>
      <material name="wheel_gold">
        <color rgba="0.827 0.667 0.129 1"/>
      </material>
    </visual>
    <!-- FIX: cylinder collision instead of mesh for smooth rolling -->
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.047" length="0.03"/>
      </geometry>
    </collision>
  </link>
  <joint name="leftrear" type="continuous">
    <origin xyz="-0.131112109546006 0.142499999999999 -0.028999999999994" rpy="-1.5707963267949 0 0"/>
    <parent link="base_link"/>
    <child  link="left_rear"/>
    <axis   xyz="0 0 1"/>
    <limit  effort="10" velocity="100"/>
    <dynamics damping="0.01" friction="0.01"/>
  </joint>

  <!-- ============================================================== -->
  <!--  RIGHT REAR WHEEL (powered — continuous joint)                 -->
  <!-- ============================================================== -->
  <link name="right_rear">
    <inertial>
      <origin xyz="5.37279659434953E-06 3.10904498124209E-06 0.0120230697296975" rpy="0 0 0"/>
      <mass value="0.126363111272001"/>
      <inertia ixx="7.94272648265279E-05" ixy="1.6049732533684E-09"  ixz="-5.03999377510644E-09"
               iyy="7.94253978332533E-05" iyz="-2.88800419664162E-09" izz="0.00013565032153422"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_bringup/meshes/right_rear.STL"/>
      </geometry>
      <material name="wheel_gold">
        <color rgba="0.827 0.667 0.129 1"/>
      </material>
    </visual>
    <!-- FIX: cylinder collision instead of mesh for smooth rolling -->
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.047" length="0.03"/>
      </geometry>
    </collision>
  </link>
  <joint name="rightrear" type="continuous">
    <origin xyz="-0.131112109546005 -0.142499999999999 -0.0289999999999937" rpy="-1.5707963267949 0 0"/>
    <parent link="base_link"/>
    <child  link="right_rear"/>
    <axis   xyz="0 0 1"/>
    <limit  effort="10" velocity="100"/>
    <dynamics damping="0.01" friction="0.01"/>
  </joint>

  <!-- ============================================================== -->
  <!--  LEFT FRONT KNUCKLE (steering — REVOLUTE with limits)          -->
  <!-- ============================================================== -->
  <link name="left_front_knuckle">
    <inertial>
      <origin xyz="-0.0069195085927054 -0.00186567476953692 7.17221471102647E-09" rpy="0 0 0"/>
      <mass value="0.0030084981775693"/>
      <inertia ixx="1.25491838679359E-07" ixy="-1.00786553248517E-07" ixz="-1.81410099511428E-13"
               iyy="3.82810606265697E-07" iyz="-2.84698744470842E-14"  izz="4.2336400843231E-07"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_bringup/meshes/left_front_knuckle.STL"/>
      </geometry>
      <material name="chassis_grey">
        <color rgba="0.792 0.820 0.933 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_bringup/meshes/left_front_knuckle.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="leftfrontknuckle" type="revolute">
    <origin xyz="0.169376641305686 0.11535109122836 -0.029000000051664" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child  link="left_front_knuckle"/>
    <axis   xyz="0 0 1"/>
    <limit  effort="10" velocity="5" lower="-0.6" upper="0.6"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- ============================================================== -->
  <!--  LEFT FRONT WHEEL (free-spinning — child of knuckle)           -->
  <!-- ============================================================== -->
  <link name="left_front">
    <inertial>
      <origin xyz="-0.00986676609693737 5.24995502093617E-06 -0.0101569567833888" rpy="0 0 0"/>
      <mass value="0.126363111272001"/>
      <inertia ixx="7.94255405774487E-05" ixy="-1.67990050048856E-09" ixz="-3.1203197493381E-09"
               iyy="7.94271220823325E-05" iyz="4.89956224317293E-09"   izz="0.00013565032153422"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_bringup/meshes/left_front.STL"/>
      </geometry>
      <material name="chassis_grey">
        <color rgba="0.792 0.820 0.933 1"/>
      </material>
    </visual>
    <!-- FIX: cylinder collision instead of mesh for smooth rolling -->
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.047" length="0.03"/>
      </geometry>
    </collision>
  </link>
  <joint name="leftfront" type="continuous">
    <origin xyz="0 0.0269999888036119 0" rpy="-1.5707963267949 0 0"/>
    <parent link="left_front_knuckle"/>
    <child  link="left_front"/>
    <axis   xyz="0 0 1"/>
    <limit  effort="0" velocity="100"/>
    <dynamics damping="0.001" friction="0.0"/>
  </joint>

  <!-- ============================================================== -->
  <!--  RIGHT FRONT KNUCKLE (steering — REVOLUTE with limits)         -->
  <!-- ============================================================== -->
  <link name="right_front_knuckle">
    <inertial>
      <origin xyz="-0.00687145694189439 0.0022731090372714 -7.17204329259147E-09" rpy="0 0 0"/>
      <mass value="0.00300849817756922"/>
      <inertia ixx="1.25491838679379E-07" ixy="1.00786553248544E-07" ixz="1.81410096406909E-13"
               iyy="3.82810606265668E-07" iyz="-2.8469873122496E-14"  izz="4.23364008432305E-07"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_bringup/meshes/right_front_knuckle.STL"/>
      </geometry>
      <material name="chassis_grey">
        <color rgba="0.792 0.820 0.933 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_bringup/meshes/right_front_knuckle.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="rightfrontknuckle" type="revolute">
    <origin xyz="0.169328589654865 -0.115758525496169 -0.0289999999484927" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child  link="right_front_knuckle"/>
    <axis   xyz="0 0 1"/>
    <limit  effort="10" velocity="5" lower="-0.6" upper="0.6"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- ============================================================== -->
  <!--  RIGHT FRONT WHEEL (free-spinning — child of knuckle)          -->
  <!-- ============================================================== -->
  <link name="right_front">
    <inertial>
      <origin xyz="0.0117938008072664 1.35946038248846E-06 0.00930811369012874" rpy="0 0 0"/>
      <mass value="0.126363111272"/>
      <inertia ixx="7.9428005805697E-05"  ixy="-8.02175722455012E-10" ixz="5.66233699547274E-09"
               iyy="7.94246568540842E-05" iyz="-1.29616563650809E-09"  izz="0.00013565032153422"/>
    </inertial>
    <!-- FIX: visual restored to mesh (was accidentally set to cylinder) -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_bringup/meshes/right_front.STL"/>
      </geometry>
      <material name="chassis_grey">
        <color rgba="0.792 0.820 0.933 1"/>
      </material>
    </visual>
    <!-- FIX: cylinder collision instead of mesh for smooth rolling -->
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.047" length="0.03"/>
      </geometry>
    </collision>
  </link>
  <joint name="rightfront" type="continuous">
    <origin xyz="0 -0.027 0" rpy="-1.5707963267949 0 0"/>
    <parent link="right_front_knuckle"/>
    <child  link="right_front"/>
    <axis   xyz="0 0 1"/>
    <limit  effort="0" velocity="100"/>
    <dynamics damping="0.001" friction="0.0"/>
  </joint>

  <!-- ============================================================== -->
  <!--  CAMERA LINK (fixed to chassis)                                -->
  <!-- ============================================================== -->
  <link name="camera_link">
    <inertial>
      <origin xyz="-0.0135378287901173 0 -0.0353920751414981" rpy="0 0 0"/>
      <mass value="0.0206168866869791"/>
      <inertia ixx="3.30124777543458E-05" ixy="0" ixz="-9.30896580437687E-06"
               iyy="3.63405838134579E-05" iyz="0"  izz="7.02199919189421E-06"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_bringup/meshes/camera_link.STL"/>
      </geometry>
      <material name="chassis_grey">
        <color rgba="0.792 0.820 0.933 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_bringup/meshes/camera_link.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="cameralink" type="fixed">
    <origin xyz="0.141101715153465 0 0.0795664425483641" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child  link="camera_link"/>
  </joint>

  <!-- ============================================================== -->
  <!--  TOF LEFT SENSOR LINK (fixed to chassis)                       -->
  <!-- ============================================================== -->
  <link name="tofL_link">
    <inertial>
      <origin xyz="0.000498097349045712 4.35778713738788E-05 0" rpy="0 0 0"/>
      <mass value="0.000175927587113891"/>
      <inertia ixx="6.68861872319417E-09" ixy="4.69777437094648E-10" ixz="0"
               iyy="1.36013824667135E-09" iyz="0"  izz="5.44000214129389E-09"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_bringup/meshes/tofL_link.STL"/>
      </geometry>
      <material name="chassis_grey">
        <color rgba="0.792 0.820 0.933 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_bringup/meshes/tofL_link.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="tofLlink" type="fixed">
    <origin xyz="0.209266648376749 0.0478158555869712 -0.0270000000000002" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child  link="tofL_link"/>
  </joint>

  <!-- ============================================================== -->
  <!--  TOF RIGHT SENSOR LINK (fixed to chassis)                      -->
  <!-- ============================================================== -->
  <link name="tofR_link">
    <inertial>
      <origin xyz="0.000498097349045268 -4.35778713743229E-05 0" rpy="0 0 0"/>
      <mass value="0.000175927587113894"/>
      <inertia ixx="6.68861872319439E-09" ixy="-4.69777437094656E-10" ixz="0"
               iyy="1.36013824667135E-09" iyz="0"  izz="5.44000214129411E-09"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_bringup/meshes/tofR_link.STL"/>
      </geometry>
      <material name="chassis_grey">
        <color rgba="0.792 0.820 0.933 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_bringup/meshes/tofR_link.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="tofRlink" type="fixed">
    <origin xyz="0.209266648376749 -0.0478158555869701 -0.0270000000000002" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child  link="tofR_link"/>
  </joint>

  <!-- ============================================================== -->
  <!--  LIDAR LINK (fixed to chassis)                                 -->
  <!-- ============================================================== -->
  <link name="lidar_link">
    <inertial>
      <origin xyz="0.00249999999999984 0 0" rpy="0 0 0"/>
      <mass value="0.00149999999999999"/>
      <inertia ixx="7.81249999999993E-08" ixy="0" ixz="0"
               iyy="3.12499999999995E-08" iyz="0"  izz="5.31249999999998E-08"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_bringup/meshes/lidar_link.STL"/>
      </geometry>
      <material name="chassis_grey">
        <color rgba="0.792 0.820 0.933 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_bringup/meshes/lidar_link.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="lidarlink" type="fixed">
    <origin xyz="0.210387890453994 0 -0.0270000000000002" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child  link="lidar_link"/>
  </joint>

  <!-- ============================================================== -->
  <!--  GAZEBO MATERIAL COLORS                                        -->
  <!-- ============================================================== -->
  <gazebo reference="base_link">
    <material>Gazebo/Grey</material>
  </gazebo>
  <gazebo reference="left_rear">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <kp>1e6</kp>
    <kd>100</kd>
    <minDepth>0.001</minDepth>
  </gazebo>
  <gazebo reference="right_rear">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <kp>1e6</kp>
    <kd>100</kd>
    <minDepth>0.001</minDepth>
  </gazebo>
  <gazebo reference="left_front">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <kp>1e6</kp>
    <kd>100</kd>
    <minDepth>0.001</minDepth>
  </gazebo>
  <gazebo reference="right_front">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <kp>1e6</kp>
    <kd>100</kd>
    <minDepth>0.001</minDepth>
  </gazebo>
  <gazebo reference="camera_link">
    <material>Gazebo/Black</material>
  </gazebo>

  <!-- ============================================================== -->
  <!--  GAZEBO PLUGINS (Harmonic / gz-sim 8)                          -->
  <!-- ============================================================== -->

  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <joint_name>leftrear</joint_name>
      <joint_name>rightrear</joint_name>
      <joint_name>leftfrontknuckle</joint_name>
      <joint_name>rightfrontknuckle</joint_name>
      <joint_name>leftfront</joint_name>
      <joint_name>rightfront</joint_name>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-ackermann-steering-system"
            name="gz::sim::systems::AckermannSteering">
      <left_joint>leftrear</left_joint>
      <right_joint>rightrear</right_joint>
      <left_steering_joint>leftfrontknuckle</left_steering_joint>
      <right_steering_joint>rightfrontknuckle</right_steering_joint>
      <wheel_base>0.3005</wheel_base>
      <wheel_separation>0.285</wheel_separation>
      <kingpin_width>0.2311</kingpin_width>
      <steering_limit>0.6</steering_limit>
      <wheel_radius>0.047</wheel_radius>
      <min_velocity>-1.0</min_velocity>
      <max_velocity>1.0</max_velocity>
      <min_acceleration>-3.0</min_acceleration>
      <max_acceleration>3.0</max_acceleration>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <odom_publish_frequency>50</odom_publish_frequency>
    </plugin>
  </gazebo>

  <!-- ============================================================ -->
  <!-- TF-LUNA LiDAR — 1D Ray Sensor (Gazebo Harmonic)             -->
  <!-- ============================================================ -->
  <gazebo reference="lidar_link">
    <sensor name="tf_luna_lidar" type="gpu_lidar">
      <pose>0 0 0 0 0 0</pose>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0.0</min_angle>
            <max_angle>0.0</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.2</min>
          <max>8.0</max>
          <resolution>0.001</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.005</stddev>
        </noise>
      </ray>
      <topic>/gz/lidar_range</topic>
    </sensor>
  </gazebo>

  <!-- ============================================================ -->
  <!-- CAMERA — IMX219 8MP (Gazebo Harmonic)                        -->
  <!-- ============================================================ -->
  <gazebo reference="camera_link">
    <sensor name="imx219_camera" type="camera">
      <pose>0 0 0 0 0 0</pose>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>30</update_rate>
      <camera name="front_camera">
        <horizontal_fov>1.3962634</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>15.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      <topic>/gz/camera/image</topic>
    </sensor>
  </gazebo>

  <!-- ============================================================ -->
  <!-- VL53L0X LEFT ToF — Short-range obstacle (Gazebo Harmonic)   -->
  <!-- ============================================================ -->
  <gazebo reference="tofL_link">
    <sensor name="tof_left" type="gpu_lidar">
      <pose>0 0 0 0 0 0</pose>
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0.0</min_angle>
            <max_angle>0.0</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.03</min>
          <max>2.0</max>
          <resolution>0.001</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.003</stddev>
        </noise>
      </ray>
      <topic>/gz/tof_left</topic>
    </sensor>
  </gazebo>

  <!-- ============================================================ -->
  <!-- VL53L0X RIGHT ToF — Short-range obstacle (Gazebo Harmonic)  -->
  <!-- ============================================================ -->
  <gazebo reference="tofR_link">
    <sensor name="tof_right" type="gpu_lidar">
      <pose>0 0 0 0 0 0</pose>
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0.0</min_angle>
            <max_angle>0.0</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.03</min>
          <max>2.0</max>
          <resolution>0.001</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.003</stddev>
        </noise>
      </ray>
      <topic>/gz/tof_right</topic>
    </sensor>
  </gazebo>

</robot>
